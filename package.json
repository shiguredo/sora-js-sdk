{
  "name": "sora-js-sdk",
  "version": "2026.1.0-canary.0",
  "description": "WebRTC SFU Sora JavaScript SDK",
  "homepage": "https://github.com/shiguredo/sora-js-sdk#readme",
  "bugs": {
    "url": "https://discord.gg/shiguredo"
  },
  "license": "Apache-2.0",
  "author": "Shiguredo Inc.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shiguredo/sora-js-sdk.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/sora.js",
  "module": "dist/sora.js",
  "exports": {
    ".": {
      "types": "./dist/sora.d.ts",
      "import": "./dist/sora.js",
      "require": "./dist/sora.js"
    }
  },
  "scripts": {
    "build": "vp build",
    "watch": "vp build --watch",
    "e2e-dev": "vp dev --config e2e-tests/vite.config.ts",
    "e2e-test": "vp build && playwright test --project='chromium'",
    "e2e-test-chrome": "vp build && playwright test --project='Google Chrome*'",
    "e2e-test-edge": "vp build && playwright test --project='Microsoft Edge*'",
    "e2e-test-webkit": "vp build && playwright test --project='WebKit'",
    "fmt": "vp fmt",
    "lint": "vp lint --type-aware",
    "typecheck": "tsc --noEmit",
    "test": "vp test run",
    "doc": "typedoc"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@types/node": "25.6.0",
    "jsdom": "29.1.1",
    "typedoc": "0.28.19",
    "typescript": "6.0.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.1.20",
    "vite-plugin-dts": "5.0.0",
    "vite-plus": "0.1.24",
    "vitest": "npm:@voidzero-dev/vite-plus-test@0.1.20"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@11.0.7"
}
