{
  "name": "sora-js-sdk",
  "version": "2026.1.0",
  "description": "WebRTC SFU Sora JavaScript SDK",
  "homepage": "https://github.com/shiguredo/sora-js-sdk#readme",
  "bugs": {
    "url": "https://discord.gg/shiguredo"
  },
  "license": "Apache-2.0",
  "author": "Shiguredo Inc.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shiguredo/sora-js-sdk.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/sora.js",
  "module": "dist/sora.js",
  "exports": {
    ".": {
      "types": "./dist/sora.d.ts",
      "import": "./dist/sora.js"
    }
  },
  "scripts": {
    "build": "vp pack",
    "watch": "vp pack --watch",
    "e2e-dev": "vp dev --config e2e-tests/vite.config.ts",
    "e2e-test": "vp pack && playwright test --project='chromium'",
    "e2e-test-chrome": "vp pack && playwright test --project='Google Chrome*'",
    "e2e-test-edge": "vp pack && playwright test --project='Microsoft Edge*'",
    "e2e-test-webkit": "vp pack && playwright test --project='WebKit'",
    "fmt": "vp fmt",
    "lint": "vp lint --type-aware",
    "typecheck": "tsc --noEmit",
    "test": "vp test run",
    "doc": "typedoc"
  },
  "devDependencies": {
    "@playwright/test": "1.61.0",
    "@types/node": "25.9.3",
    "jsdom": "29.1.1",
    "typedoc": "0.28.19",
    "typescript": "6.0.3",
    "vite-plus": "0.1.24"
  },
  "engines": {
    "node": ">=22.18.0",
    "pnpm": ">=11"
  },
  "packageManager": "pnpm@11.7.0"
}
