{
  "name": "sora-js-sdk",
  "version": "2026.1.0-canary.0",
  "description": "WebRTC SFU Sora JavaScript SDK",
  "homepage": "https://github.com/shiguredo/sora-js-sdk#readme",
  "bugs": {
    "url": "https://discord.gg/shiguredo"
  },
  "license": "Apache-2.0",
  "author": "Shiguredo Inc.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shiguredo/sora-js-sdk.git"
  },
  "files": [
    "dist"
  ],
  "main": "dist/sora.js",
  "module": "dist/sora.mjs",
  "exports": {
    ".": {
      "types": "./dist/sora.d.ts",
      "import": "./dist/sora.mjs",
      "require": "./dist/sora.mjs"
    }
  },
  "scripts": {
    "build": "vite build",
    "watch": "vite build --watch",
    "e2e-dev": "vite --config e2e-tests/vite.config.ts",
    "e2e-test": "pnpm build && playwright test --project='chromium'",
    "e2e-test-chrome": "pnpm build && playwright test --project='Google Chrome*'",
    "e2e-test-edge": "pnpm build && playwright test --project='Microsoft Edge*'",
    "e2e-test-webkit": "pnpm build && playwright test --project='WebKit'",
    "fmt": "oxfmt --write .",
    "lint": "oxlint --type-aware",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "doc": "typedoc"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@types/node": "25.3.5",
    "jsdom": "28.1.0",
    "oxfmt": "0.36.0",
    "oxlint": "1.51.0",
    "oxlint-tsgolint": "0.16.0",
    "typedoc": "0.28.17",
    "typescript": "5.9.3",
    "vite": "npm:rolldown-vite@^7.3.1",
    "vite-plugin-dts": "4.5.4",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=8"
  }
}
